# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
postgres-local.log
.pnpm-debug.log*
dev-server.log
dev-server-error.log
backend-dev.log
backend-dev-error.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# strapi local data
backend/.tmp/
backend/.strapi/
backend/.strapi-updater.json
backend/dist/
backend/build/
backend/types/generated/
backend/public/uploads/*
!backend/public/uploads/.gitkeep

# codex local runtime/log artifacts
.codex/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local
.env
.env.example