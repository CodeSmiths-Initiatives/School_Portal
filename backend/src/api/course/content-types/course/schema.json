{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "Course owned by a college and department."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "code": {
      "type": "string",
      "required": true
    },
    "level": {
      "type": "integer"
    },
    "semester": {
      "type": "enumeration",
      "enum": ["first", "second", "summer"]
    },
    "creditUnits": {
      "type": "integer",
      "default": 3
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "inactive", "archived"],
      "default": "active"
    },
    "college": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::college.college",
      "inversedBy": "courses"
    },
    "department": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department",
      "inversedBy": "courses"
    }
  }
}

