{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "Course owned by a college and department."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "code": {
      "type": "string",
      "required": true
    },
    "level": {
      "type": "integer"
    },
    "semester": {
      "type": "enumeration",
      "enum": ["first", "second", "summer"]
    },
    "creditUnits": {
      "type": "integer",
      "default": 3
    },
    "description": {
      "type": "text"
    },
    "type": {
      "type": "enumeration",
      "enum": ["Core", "Elective", "Required", "Borrowed", "Carryover"],
      "default": "Core"
    },
    "levels": {
      "type": "json"
    },
    "mode": {
      "type": "enumeration",
      "enum": ["On-Site", "Online", "Hybrid"],
      "default": "On-Site"
    },
    "schedule": {
      "type": "string"
    },
    "lecturer": {
      "type": "string"
    },
    "approvalStatus": {
      "type": "enumeration",
      "enum": ["Pending", "Approved", "Rejected"],
      "default": "Pending"
    },
    "approvalNote": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "inactive", "archived"],
      "default": "active"
    },
    "college": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::college.college",
      "inversedBy": "courses"
    },
    "department": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department",
      "inversedBy": "courses"
    }
  }
}
