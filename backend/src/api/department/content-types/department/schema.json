{
  "kind": "collectionType",
  "collectionName": "departments",
  "info": {
    "singularName": "department",
    "pluralName": "departments",
    "displayName": "Department",
    "description": "Department scoped to a college and optionally a faculty."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "code": {
      "type": "string"
    },
    "college": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::college.college",
      "inversedBy": "departments"
    },
    "faculty": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::faculty.faculty",
      "inversedBy": "departments"
    },
    "courses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::course.course",
      "mappedBy": "department"
    }
  }
}

