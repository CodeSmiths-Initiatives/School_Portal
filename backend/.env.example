HOST=0.0.0.0
PORT=1337

# Generate these values for every environment. Do not commit real secrets.
APP_KEYS=replaceWithGeneratedKey1,replaceWithGeneratedKey2,replaceWithGeneratedKey3,replaceWithGeneratedKey4
API_TOKEN_SALT=replaceWithGeneratedSalt
ADMIN_JWT_SECRET=replaceWithGeneratedSecret
TRANSFER_TOKEN_SALT=replaceWithGeneratedSalt
JWT_SECRET=replaceWithGeneratedSecret
ENCRYPTION_KEY=replaceWithGeneratedEncryptionKey

# Local development defaults to sqlite.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Strapi Cloud / managed Postgres can use these later.
# DATABASE_CLIENT=postgres
# DATABASE_URL=
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_NAME=
# DATABASE_USERNAME=
# DATABASE_PASSWORD=
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Frontend origin used by CORS. Update after deployment.
FRONTEND_URL=http://localhost:3000
